{
	"name": "obsidian-notion-database-sync",
	"version": "0.9.11",
	"description": "Sync Notion databases and pages into your vault as Markdown.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest run",
		"test:integration": "VITEST_INTEGRATION=1 vitest run",
		"test:all": "npm test && npm run test:integration"
	},
	"keywords": [],
	"author": "ranli",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.11.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.25.0",
		"obsidian": "latest",
		"tslib": "^2.4.0",
		"tsx": "^4.21.0",
		"typescript": "^5.5.0",
		"vitest": "^3.1.2"
	},
	"dependencies": {
		"@notionhq/client": "^5.3.0"
	}
}
